{
    "name": "lumensistemas/lens",
    "description": "Lumen's PHP code-quality conventions, baked in. Wraps php-cs-fixer, Rector and PHPStan with shipped config.",
    "type": "library",
    "license": "MIT",
    "keywords": ["lint", "static-analysis", "php-cs-fixer", "rector", "phpstan", "laravel", "lumen"],
    "homepage": "https://github.com/lumensistemas/lens",
    "require": {
        "php": "^8.3",
        "ext-json": "*"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.64",
        "humbug/box": "^4.7",
        "larastan/larastan": "^3.0",
        "pestphp/pest": "^4.0",
        "phpstan/phpstan": "^2.1",
        "rector/rector": "^2.0",
        "symfony/console": "^6.4 || ^7.0",
        "symfony/finder": "^6.4 || ^7.0",
        "symfony/process": "^6.4 || ^7.0"
    },
    "autoload": {
        "psr-4": {
            "LumenSistemas\\Lens\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LumenSistemas\\Lens\\Tests\\": "tests/"
        }
    },
    "bin": ["builds/lens"],
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": true,
            "pestphp/pest-plugin": true
        }
    },
    "scripts": {
        "lens": "@php bin/lens",
        "build": "@php bin/build.php",
        "test": "@php vendor/bin/pest"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
